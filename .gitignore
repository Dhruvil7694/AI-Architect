########################################
# Root .gitignore for Architecture-AI  #
# Django backend + Next.js frontend   #
########################################

##############
# Node / JS #
##############

# Dependencies
node_modules/
frontend/node_modules/

# Next.js build output
.next/
frontend/.next/
out/
build/

# Yarn / pnpm
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.pnpm-debug.log*

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# TypeScript
*.tsbuildinfo
next-env.d.ts

#############
# Python   #
#############

__pycache__/
*.py[cod]
*.pyo
*.pyc
*.pyd

# Virtual environments
.venv/
venv/
env/

# Django / Python build artifacts
*.log
db.sqlite3
*.sqlite3

#############
# General  #
#############

# OS / editor files
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/

# Environment / secrets
.env*
.vercel

# Coverage / test output
coverage/
.coverage
.coverage.*
htmlcov/
pytest-cache/
